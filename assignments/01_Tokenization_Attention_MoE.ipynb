{"cells": [{"cell_type": "markdown", "metadata": {}, "source": ["# Assignment: Tokenization, Attention Mechanism & Mixture of Experts\n\nThis notebook explores the concepts and implementations of Tokenization, Attention Mechanism and Mixture of Experts (MoE). You will engage in practical exercises to implement these concepts using provided datasets and problems."]},{"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["# Import necessary libraries\nimport nltk\nimport numpy as np\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\n\n# Ensure you have the required nltk data\nnltk.download('punkt')\n\n# A simple example of tokenization\ntext = \"Hello, how are you?\"\ntokens = nltk.word_tokenize(text)\nprint(tokens)\n"]},{"cell_type": "markdown", "metadata": {}, "source": ["## Task 1: Implement Tokenization\n- Implement your own tokenization method using Python and compare it with nltk's tokenization.\n\n## Task 2: Implement Attention Mechanism\n- Implement a simple attention mechanism using PyTorch and apply it to an example sequence.\n\n## Task 3: Explore Mixture of Experts\n- Implement a basic Mixture of Experts model and analyze its performance on a dataset."]},{"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["# Task 1: Custom Tokenization Implementation\ndef custom_tokenize(text):\n    # Implement simple custom tokenization logic\n    return text.split()\n\n# Custom Tokenization Example\ncustom_tokens = custom_tokenize(text)\nprint(custom_tokens)\n"]},{"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["# Task 2: Simple Attention Mechanism\nclass SimpleAttention(nn.Module):\n    def __init__(self):\n        super(SimpleAttention, self).__init__()\n\n    def forward(self, query, key, value):\n        scores = torch.matmul(query, key.transpose(-2, -1))\n        attention_weights = F.softmax(scores, dim=-1)\n        output = torch.matmul(attention_weights, value)\n        return output\n\n# Testing Attention Mechanism\nquery = torch.rand(1, 10, 64)  # (batch_size, sequence_length, embedding_dim)\nkey = torch.rand(1, 10, 64)\nvalue = torch.rand(1, 10, 64)\nattention_layer = SimpleAttention()\noutput = attention_layer(query, key, value)\nprint(output.shape)\n"]},{"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["# Task 3: Mixture of Experts Example\nclass MixtureOfExperts(nn.Module):\n    def __init__(self, num_experts, input_dim, output_dim):\n        super(MixtureOfExperts, self).__init__()\n        self.experts = nn.ModuleList([nn.Linear(input_dim, output_dim) for _ in range(num_experts)])\n        self.gate = nn.Linear(input_dim, num_experts)\n\n    def forward(self, x):\n        gate_output = F.softmax(self.gate(x), dim=-1)\n        expert_outputs = [expert(x) for expert in self.experts]\n        output = sum(g * expert for g, expert in zip(gate_output, expert_outputs))\n        return output\n\n# Testing Mixture of Experts\nnum_experts = 3\nin_dim = 64\nout_dim = 32\nmix_experts = MixtureOfExperts(num_experts, in_dim, out_dim)\ninput_data = torch.rand(1, in_dim)\noutput = mix_experts(input_data)\nprint(output.shape)"]}]}